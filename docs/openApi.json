{
  "openapi": "3.0.3",
  "info": {
    "title": "signalk-imo-alerts",
    "version": "0.1.0",
    "description": "Spoken alert announcements and IMO A.1021(26) alert tone patterns"
  },
  "paths": {
    "/plugins/signalk-imo-alerts/active": {
      "get": {
        "summary": "List currently active (voiceable) alerts",
        "responses": {
          "200": {
            "description": "Active alerts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "path": { "type": "string" },
                      "priority": { "type": "number" },
                      "message": { "type": "string" },
                      "state": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/plugins/signalk-imo-alerts/options": {
      "get": {
        "summary": "List available priorities and built-in tone codes, for the test-mode form",
        "responses": {
          "200": {
            "description": "Available options",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "priorities": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "value": { "type": "number" },
                          "label": { "type": "string" },
                          "configuredDefault": {
                            "type": "object",
                            "description": "The currently configured default tone for this priority (cautionTone/warningTone/alarmTone/emergencyAlarmTone in plugin config)",
                            "properties": {
                              "preset": { "type": "string", "description": "Built-in code, or 'custom'" },
                              "pattern": { "type": "string", "description": "Custom pattern, set when preset is 'custom'" }
                            }
                          }
                        }
                      }
                    },
                    "toneCodes": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "value": { "type": "string" },
                          "label": { "type": "string" },
                          "description": { "type": "string", "description": "Short human-readable description, e.g. 'Square pulse train'" }
                        }
                      }
                    },
                    "musterListCodes": {
                      "type": "array",
                      "description": "Configured 1.b ship-specific muster-list codes (plugin config), offered as additional selectable tone options",
                      "items": {
                        "type": "object",
                        "properties": {
                          "path": { "type": "string" },
                          "zone": { "type": ["string", "null"] },
                          "pattern": { "type": "string" }
                        }
                      }
                    },
                    "voice": {
                      "type": "object",
                      "description": "Configured voice/language settings, so the webapp can default its test-mode voice field to what's actually configured. Used for both local-speaker and browser playback (one TTS engine serves both).",
                      "properties": {
                        "language": { "type": "string" },
                        "serverVoice": { "type": "string", "description": "espeak-ng voice/variant" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/plugins/signalk-imo-alerts/tone-clip": {
      "get": {
        "summary": "Serve a tone clip's audio, either a built-in code, a custom pattern, or a priority's default",
        "parameters": [
          { "name": "code", "in": "query", "schema": { "type": "string" }, "description": "Built-in tone code, e.g. '1a'" },
          { "name": "pattern", "in": "query", "schema": { "type": "string" }, "description": "Custom '<freqHz>:<durationMs> ...' pattern" },
          { "name": "priority", "in": "query", "schema": { "type": "number" }, "description": "Priority to use its default tone" }
        ],
        "responses": {
          "200": { "description": "audio/wav clip" },
          "400": { "description": "No code/pattern/priority given, or invalid pattern" },
          "404": { "description": "Clip not found" }
        }
      }
    },
    "/plugins/signalk-imo-alerts/test-announce": {
      "post": {
        "summary": "Manually trigger a test announcement, combining any priority/tone/message/language/voice (for verifying pronunciation, volume, tone selection, and voice model before trusting it live)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["priority"],
                "properties": {
                  "priority": { "type": "number" },
                  "message": { "type": "string" },
                  "toneCode": { "type": "string", "description": "Built-in code, or 'none'; omit to use the priority's default" },
                  "tonePattern": { "type": "string", "description": "Custom pattern, overrides toneCode if given" },
                  "language": { "type": "string" },
                  "voice": { "type": "string", "description": "espeak-ng voice/variant override, e.g. 'en-us'; overrides the configured serverVoice/language for this announcement only" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Accepted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "spokenMessage": {
                      "type": ["string", "null"],
                      "description": "The message after pronunciation substitution - use this (not the raw message sent) for a browser-side /voice-clip preview, so it matches server-side TTS exactly"
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Invalid request body" }
        }
      }
    },
    "/plugins/signalk-imo-alerts/voice-clip": {
      "get": {
        "summary": "Synthesize and serve a message's raw audio on demand (not cached - message text is usually dynamic). Used by the webapp to play the exact same audio the local speaker would.",
        "parameters": [
          { "name": "message", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Text to synthesize - pronunciation substitution is NOT applied here; pass already-substituted text (see /test-announce's spokenMessage, or /active's message for real alerts)" },
          { "name": "language", "in": "query", "schema": { "type": "string" }, "description": "Overrides the configured language for this request only" },
          { "name": "voice", "in": "query", "schema": { "type": "string" }, "description": "Overrides the configured serverVoice for this request only" }
        ],
        "responses": {
          "200": { "description": "audio/wav clip" },
          "400": { "description": "No message given" },
          "503": { "description": "Speech synthesis unavailable (e.g. espeak-ng missing)" }
        }
      }
    },
    "/plugins/signalk-imo-alerts/acknowledge": {
      "post": {
        "summary": "Fully acknowledge an active alert (stops repeats until state changes again)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["path"],
                "properties": { "path": { "type": "string" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Accepted" },
          "400": { "description": "Invalid request body" }
        }
      }
    },
    "/plugins/signalk-imo-alerts/silence": {
      "post": {
        "summary": "Temporarily silence an active alert (repeat resumes automatically unless also acknowledged - MSC.302(87) silenced vs. acknowledged states)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["path"],
                "properties": { "path": { "type": "string" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Accepted" },
          "400": { "description": "Invalid request body" }
        }
      }
    }
  }
}
